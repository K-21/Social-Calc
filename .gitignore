## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio cache/options directory
.vs/

# Visual Studio Code
.vscode/
*.code-workspace

# Rider
.idea/
*.sln.iml

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*.json

# NuGet Packages
*.nupkg
*.snupkg
packages/

# Entity Framework Migrations (keep folder, ignore auto-generated)
# Migrations/*.cs  # Uncomment if you don't want to track migrations

# ========================
# SENSITIVE FILES - NEVER COMMIT
# ========================
appsettings.json
appsettings.Development.json
appsettings.Production.json
appsettings.*.json
!appsettings.template.json
.env
.env.*
secrets.json
*.pfx
*.p12

# ========================
# PHP / COMPOSER
# ========================
excelinterop/vendor/
excelinterop/tmp/
excelinterop/.DS_Store

# ========================
# USER DATA & UPLOADS
# ========================
uploads/
users/
data/

# ========================
# LOGS
# ========================
logs/
*.log

# ========================
# OS FILES
# ========================
.DS_Store
Thumbs.db
desktop.ini
*.swp
*~

# ========================
# NODE (if using npm/yarn)
# ========================
node_modules/
npm-debug.log
yarn-error.log
package-lock.json

# ========================
# DATABASE FILES
# ========================
*.db
*.sqlite
*.sqlite3
*.mdf
*.ldf

# ========================
# TEMP & CACHE
# ========================
*.tmp
*.temp
*.cache
.cache/
