@{
    ViewData["Title"] = "Home";
}

<div class="row">
    <div class="col-lg-6">
        <div class="card shadow-lg mb-4">
            <div class="card-body p-5">
                <h1 class="card-title mb-4">
                    <i class="fas fa-calculator fa-2x text-primary"></i>
                </h1>
                <h2>Welcome to Social Calc</h2>
                <p class="card-text lead">
                    A powerful, collaborative spreadsheet editor. Create, edit, and share your data seamlessly.
                </p>
                <ul class="list-unstyled">
                    <li class="mb-2"><i class="fas fa-check text-success"></i> Create unlimited spreadsheets</li>
                    <li class="mb-2"><i class="fas fa-check text-success"></i> Import/export Excel files</li>
                    <li class="mb-2"><i class="fas fa-check text-success"></i> Export to PDF</li>
                    <li class="mb-2"><i class="fas fa-check text-success"></i> Real-time collaboration</li>
                </ul>
                
                @if (User.Identity?.IsAuthenticated ?? false)
                {
                    <a href="/Sheets" class="btn btn-primary btn-lg mt-4">
                        <i class="fas fa-table"></i> Go to My Sheets
                    </a>
                }
                else
                {
                    <a href="/Auth/Register" class="btn btn-primary btn-lg mt-4 me-2">
                        <i class="fas fa-user-plus"></i> Get Started
                    </a>
                    <a href="/Auth/Login" class="btn btn-outline-primary btn-lg mt-4">
                        <i class="fas fa-sign-in-alt"></i> Login
                    </a>
                }
            </div>
        </div>
    </div>
    
    <div class="col-lg-6">
        <div class="card shadow-lg">
            <div class="card-body p-5">
                <h3 class="card-title mb-4">Features</h3>
                
                <div class="feature-item mb-4">
                    <h5><i class="fas fa-lock text-primary"></i> Secure</h5>
                    <p class="text-muted">Your data is encrypted and securely stored.</p>
                </div>
                
                <div class="feature-item mb-4">
                    <h5><i class="fas fa-share-alt text-primary"></i> Shareable</h5>
                    <p class="text-muted">Easily share sheets with colleagues and collaborate in real-time.</p>
                </div>
                
                <div class="feature-item mb-4">
                    <h5><i class="fas fa-exchange-alt text-primary"></i> Import/Export</h5>
                    <p class="text-muted">Work with Excel, CSV, and other formats seamlessly.</p>
                </div>
                
                <div class="feature-item">
                    <h5><i class="fas fa-chart-bar text-primary"></i> Analytics</h5>
                    <p class="text-muted">Create charts and visualizations from your data.</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
        }
        
        .card {
            border: none;
            border-radius: 10px;
        }
        
        .feature-item {
            padding: 15px;
            border-left: 4px solid #667eea;
            background-color: #f8f9fa;
            border-radius: 5px;
        }
        
        main {
            background-color: white;
            margin-top: 30px;
            border-radius: 10px;
            padding: 40px !important;
        }
    </style>
}
