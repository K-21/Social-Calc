@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container mx-auto px-4 py-12 max-w-4xl">
    <h1 class="text-3xl font-bold mb-8 text-gray-900">Privacy Policy</h1>
    
    <div class="prose prose-blue max-w-none">
        <p class="text-lg text-gray-600 mb-6">Last updated: @DateTime.Now.ToString("MMMM dd, yyyy")</p>

        <section class="mb-8">
            <h2 class="text-2xl font-semibold mb-4 text-gray-800">1. Information We Collect</h2>
            <p class="text-gray-600 mb-4">We collect information that you provide directly to us, including your email address and any Google Sheets data you explicitly choose to export using our Add-on. We only access the specific sheets you authorize.</p>
        </section>

        <section class="mb-8">
            <h2 class="text-2xl font-semibold mb-4 text-gray-800">2. How We Use Your Information</h2>
            <p class="text-gray-600 mb-4">We use your information exclusively to provide the SocialCalc service. Specifically, your spreadsheet data is imported into your private SocialCalc account so you can view and edit it within our application.</p>
        </section>

        <section class="mb-8">
            <h2 class="text-2xl font-semibold mb-4 text-gray-800">3. Information Sharing</h2>
            <p class="text-gray-600 mb-4">We do not sell, rent, or share your personal information or spreadsheet data with third parties. Your data is stored securely and is only accessible by you.</p>
        </section>

        <section class="mb-8">
            <h2 class="text-2xl font-semibold mb-4 text-gray-800">4. Data Deletion</h2>
            <p class="text-gray-600 mb-4">You may request the deletion of your account and all associated data at any time by contacting our support team. Once requested, your data will be permanently removed from our servers within 30 days.</p>
        </section>

        <section class="mb-8">
            <h2 class="text-2xl font-semibold mb-4 text-gray-800">5. Contact Us</h2>
            <p class="text-gray-600 mb-4">If you have any questions about this Privacy Policy, please contact us at <a href="/Home/Support" class="text-blue-600 hover:underline">our Support page</a>.</p>
        </section>
    </div>
</div>
