@{
    ViewData["Title"] = "Support";
}

<div class="container mx-auto px-4 py-12 max-w-4xl text-center">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-12">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-blue-100 text-blue-600 mb-6">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
            </svg>
        </div>
        
        <h1 class="text-3xl font-bold mb-4 text-gray-900">How can we help?</h1>
        <p class="text-lg text-gray-600 mb-8 max-w-2xl mx-auto">
            If you need help using SocialCalc, have found a bug, or want to suggest a new feature for the Google Workspace Add-on, we would love to hear from you!
        </p>

        <div class="bg-gray-50 rounded-xl p-8 mb-8 text-left">
            <h2 class="text-xl font-semibold mb-4 text-gray-800">Contact Us Directly</h2>
            <p class="text-gray-600 mb-2">You can reach our lead developer directly via email:</p>
            <a href="mailto:Enroll@tickervalue.com" class="text-xl font-medium text-blue-600 hover:text-blue-800 transition-colors">
                Enroll@tickervalue.com
            </a>
        </div>

        <p class="text-gray-500 text-sm">We typically respond to all support inquiries within 24-48 business hours.</p>
    </div>
</div>
