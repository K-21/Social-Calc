@{
    ViewData["Title"] = "Terms of Service";
}

<div class="container mx-auto px-4 py-12 max-w-4xl">
    <h1 class="text-3xl font-bold mb-8 text-gray-900">Terms of Service</h1>
    
    <div class="prose prose-blue max-w-none">
        <p class="text-lg text-gray-600 mb-6">Last updated: @DateTime.Now.ToString("MMMM dd, yyyy")</p>

        <section class="mb-8">
            <h2 class="text-2xl font-semibold mb-4 text-gray-800">1. Acceptance of Terms</h2>
            <p class="text-gray-600 mb-4">By accessing and using SocialCalc and its associated Google Workspace Add-on, you agree to be bound by these Terms of Service. If you do not agree to these terms, please do not use our services.</p>
        </section>

        <section class="mb-8">
            <h2 class="text-2xl font-semibold mb-4 text-gray-800">2. Description of Service</h2>
            <p class="text-gray-600 mb-4">SocialCalc provides a platform for viewing, editing, and managing spreadsheet data. Our Google Workspace Add-on allows users to seamlessly import data from Google Sheets into the SocialCalc platform.</p>
        </section>

        <section class="mb-8">
            <h2 class="text-2xl font-semibold mb-4 text-gray-800">3. User Responsibilities</h2>
            <p class="text-gray-600 mb-4">You are responsible for maintaining the confidentiality of your account credentials and your Personal Access Tokens (PATs). You are solely responsible for the data you choose to import and manage within SocialCalc.</p>
        </section>

        <section class="mb-8">
            <h2 class="text-2xl font-semibold mb-4 text-gray-800">4. Limitation of Liability</h2>
            <p class="text-gray-600 mb-4">SocialCalc is provided "as is" without warranties of any kind. We shall not be liable for any data loss, service interruptions, or damages arising from the use of our platform or add-on.</p>
        </section>

        <section class="mb-8">
            <h2 class="text-2xl font-semibold mb-4 text-gray-800">5. Changes to Terms</h2>
            <p class="text-gray-600 mb-4">We reserve the right to modify these terms at any time. Continued use of the service constitutes acceptance of the new terms.</p>
        </section>
    </div>
</div>
