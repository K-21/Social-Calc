@model List<SocialCalc.Web.Models.PersonalAccessToken>

@{
    ViewData["Title"] = "Developer Settings - API Tokens";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-12">
            <h2 class="fw-bold">Developer Settings</h2>
            <p class="text-muted">Manage your Personal Access Tokens for third-party integrations like the Google Workspace Add-on.</p>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["NewToken"] != null)
    {
        <div class="card border-success mb-4 shadow-sm">
            <div class="card-body bg-light">
                <h5 class="card-title text-success"><i class="bi bi-key-fill me-2"></i>New API Token Generated</h5>
                <p class="card-text text-danger fw-bold">Please copy your personal access token now. You won't be able to see it again!</p>
                <div class="input-group">
                    <input type="text" class="form-control font-monospace" id="newTokenInput" value="@TempData["NewToken"]" readonly>
                    <button class="btn btn-success" type="button" onclick="copyToken()">
                        <i class="bi bi-clipboard"></i> Copy
                    </button>
                </div>
            </div>
        </div>

        <script>
            function copyToken() {
                var copyText = document.getElementById("newTokenInput");
                copyText.select();
                copyText.setSelectionRange(0, 99999);
                navigator.clipboard.writeText(copyText.value);
                alert("Token copied to clipboard!");
            }
        </script>
    }

    <div class="card shadow-sm mb-5">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Your Active API Tokens</h5>
            <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#generateTokenModal">
                <i class="bi bi-plus-circle me-1"></i> Generate New Token
            </button>
        </div>
        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Name</th>
                                <th>Created</th>
                                <th>Last Used</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var token in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-key fs-4 text-muted me-3"></i>
                                            <div>
                                                <strong>@token.Name</strong>
                                                <div class="text-muted small font-monospace">sc_******************</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>@token.CreatedAt.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        @if (token.LastUsedAt.HasValue)
                                        {
                                            @token.LastUsedAt.Value.ToString("MMM dd, yyyy HH:mm")
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Never used</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <form asp-action="RevokeToken" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to revoke this token? Any integrations using it will instantly lose access.');">
                                            <input type="hidden" name="tokenId" value="@token.Id" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                                Revoke
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center p-5 text-muted">
                    <i class="bi bi-shield-lock display-4 mb-3 d-block"></i>
                    <p>You don't have any active API tokens.</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- Generate Token Modal -->
<div class="modal fade" id="generateTokenModal" tabindex="-1" aria-labelledby="generateTokenModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="GenerateToken" method="post">
                <div class="modal-header">
                    <h5 class="modal-title" id="generateTokenModalLabel">Generate New API Token</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="tokenName" class="form-label">What's this token for?</label>
                        <input type="text" class="form-control" id="tokenName" name="tokenName" placeholder="e.g. Google Sheets Add-on" required maxlength="100">
                        <div class="form-text">Give your token a descriptive name so you remember what it's used for.</div>
                    </div>
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        Keep this token secret. Anyone with your token can access and edit your spreadsheets!
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Generate Token</button>
                </div>
            </form>
        </div>
    </div>
</div>
