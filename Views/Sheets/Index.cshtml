@model List<SocialCalc.Web.Models.Sheet>

@{
    ViewData["Title"] = "My Sheets";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-md-6">
            <h1><i class="fas fa-table"></i> My Spreadsheets</h1>
        </div>
        <div class="col-md-6 text-end">
            <button class="btn btn-primary btn-lg" id="btnNewSheet">
                <i class="fas fa-plus"></i> New Sheet
            </button>
            <button class="btn btn-secondary btn-lg" data-bs-toggle="modal" data-bs-target="#importModal">
                <i class="fas fa-file-import"></i> Import
            </button>
            <a href="/logout" class="btn btn-danger btn-lg">
                <i class="fas fa-sign-out-alt"></i> Logout
            </a>
        </div>
    </div>

    @if (Model != null && Model.Count > 0)
    {
        <div class="row">
            @foreach (var sheet in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">
                                <i class="fas fa-sheet"></i> @sheet.FileName
                            </h5>
                            <p class="card-text text-muted small">
                                Created: @sheet.CreatedAt.ToString("MMM dd, yyyy")
                                <br />
                                Updated: @sheet.UpdatedAt.ToString("MMM dd, yyyy")
                            </p>
                        </div>
                        <div class="card-footer bg-transparent border-top">
                            <a href="/Sheets/Editor/@sheet.Id" class="btn btn-sm btn-primary">
                                <i class="fas fa-edit"></i> Edit
                            </a>
                            <div class="btn-group" role="group">
                                <button type="button" class="btn btn-sm btn-success dropdown-toggle" data-bs-toggle="dropdown">
                                    <i class="fas fa-download"></i> Export
                                </button>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" href="#" onclick="exportSheet(@sheet.Id, 'gdrive')">
                                        <i class="fab fa-google-drive text-success"></i> Save to Google Drive
                                    </a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" href="#" onclick="exportSheet(@sheet.Id, 'xlsx')">
                                        <i class="fas fa-file-excel"></i> Excel (.xlsx)
                                    </a></li>
                                    <li><a class="dropdown-item" href="#" onclick="exportSheet(@sheet.Id, 'csv')">
                                        <i class="fas fa-file-csv"></i> CSV (.csv)
                                    </a></li>
                                    <li><a class="dropdown-item" href="#" onclick="exportSheet(@sheet.Id, 'ods')">
                                        <i class="fas fa-file-alt"></i> OpenDocument (.ods)
                                    </a></li>
                                    <li><a class="dropdown-item" href="#" onclick="exportSheet(@sheet.Id, 'html')">
                                        <i class="fas fa-code"></i> HTML (.html)
                                    </a></li>
                                </ul>
                            </div>
                            <button class="btn btn-sm btn-danger" onclick="deleteSheet(@sheet.Id)">
                                <i class="fas fa-trash"></i> Delete
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info text-center py-5">
            <i class="fas fa-inbox fa-3x mb-3"></i>
            <p>No spreadsheets yet. <a href="#" onclick="createNewSheet()">Create one now!</a></p>
        </div>
    }
</div>

<!-- Import Modal -->
<div class="modal fade" id="importModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-file-import"></i> Import Spreadsheet</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="importForm" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label for="fileInput" class="form-label">Select Excel or CSV File</label>
                        <input type="file" class="form-control" id="fileInput" name="file" accept=".xlsx,.xls,.csv" required />
                        <small class="text-muted">Supported formats: Excel (.xlsx, .xls), CSV</small>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="importSheet()">
                    <i class="fas fa-upload"></i> Import
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function createNewSheet() {
            const sheetName = prompt("Enter sheet name:");
            if (!sheetName) return;

            console.log('Creating new sheet:', sheetName);
            
            fetch('/Sheets/Create', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ fileName: sheetName })
            })
            .then(r => r.json())
            .then(data => {
                console.log('Create response:', data);
                if (data.success) {
                    console.log('Sheet created successfully, navigating to editor');
                    window.location.href = `/Sheets/Editor/${data.id}`;
                } else {
                    console.error('Create failed:', data.message);
                    alert('Error creating sheet: ' + data.message);
                }
            })
            .catch(e => {
                console.error('Create error:', e);
                alert('Error: ' + e.message);
            });
        }

        document.getElementById('btnNewSheet').addEventListener('click', createNewSheet);

        function exportSheet(sheetId, format) {
            console.log('Export sheet:', sheetId, 'format:', format);
            if (format === 'gdrive') {
                window.location.href = `/sheets/export-gdrive/${sheetId}`;
            } else if (format) {
                console.log('Exporting to format:', format);
                window.location.href = `/Sheets/Export-Format/${sheetId}/${format}`;
            } else {
                console.log('Exporting to default Excel format');
                window.location.href = `/Sheets/Export/${sheetId}`;
            }
        }

        function deleteSheet(sheetId) {
            console.log('Delete button clicked for sheet ID:', sheetId);
            if (!confirm('Are you sure you want to delete this sheet?')) {
                console.log('Delete cancelled by user');
                return;
            }

            console.log('Sending DELETE request to:', `/Sheets/Delete/${sheetId}`);
            fetch(`/Sheets/Delete/${sheetId}`, { method: 'POST' })
            .then(r => {
                console.log('Delete response status:', r.status);
                return r.json();
            })
            .then(data => {
                console.log('Delete response data:', data);
                if (data.success) {
                    console.log('Delete successful, reloading page');
                    location.reload();
                } else {
                    alert('Error deleting sheet: ' + data.message);
                }
            })
            .catch(e => {
                console.error('Delete error:', e);
                alert('Error: ' + e.message);
            });
        }

        function importSheet() {
            const fileInput = document.getElementById('fileInput');
            console.log('Import sheet - file selected:', fileInput.files[0]?.name);
            
            const formData = new FormData();
            formData.append('file', fileInput.files[0]);

            fetch('/Sheets/Import', {
                method: 'POST',
                body: formData
            })
            .then(r => r.json())
            .then(data => {
                console.log('Import response:', data);
                if (data.success) {
                    console.log('Import successful, navigating to editor');
                    bootstrap.Modal.getInstance(document.getElementById('importModal')).hide();
                    window.location.href = `/Sheets/Editor/${data.id}`;
                } else {
                    console.error('Import failed:', data.message);
                    alert('Error importing file: ' + data.message);
                }
            })
            .catch(e => {
                console.error('Import error:', e);
                alert('Error: ' + e.message);
            });
        }

        // Check if we just saved a sheet and auto-refresh if needed
        document.addEventListener('DOMContentLoaded', function() {
            if (localStorage.getItem('justSavedSheet') === 'true') {
                localStorage.removeItem('justSavedSheet');
                console.log('Just returned from saving a sheet - refreshing page');
                window.location.reload();
            }
        });
    </script>
}
