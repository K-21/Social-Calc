@model List<SocialCalc.Web.Models.Sheet>

@{
    ViewData["Title"] = "My Sheets";
}

<div class="container-fluid">
    @Html.AntiForgeryToken()
    <div class="row mb-4">
        <div class="col-md-6">
            <h1><i class="fas fa-table"></i> My Spreadsheets</h1>
        </div>
        <div class="col-md-6 text-end">
            <button class="btn btn-primary btn-lg" id="btnNewSheet">
                <i class="fas fa-plus"></i> New Sheet
            </button>
            <button class="btn btn-secondary btn-lg" data-bs-toggle="modal" data-bs-target="#importModal">
                <i class="fas fa-file-import"></i> Import
            </button>
            <form method="post" action="/logout" style="display: inline;">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-danger btn-lg">
                    <i class="fas fa-sign-out-alt"></i> Logout
                </button>
            </form>
        </div>
    </div>

    @if (Model != null && Model.Count > 0)
    {
        <div class="row">
            @foreach (var sheet in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title d-flex justify-content-between align-items-center">
                                <span><i class="fas fa-table"></i> <span id="sheetName-@sheet.Id">@sheet.FileName</span></span>
                                <button class="btn btn-sm btn-outline-secondary border-0 btn-rename" data-sheet-id="@sheet.Id" data-filename="@sheet.FileName" title="Rename">
                                    <i class="fas fa-pen"></i>
                                </button>
                            </h5>
                            <p class="card-text text-muted small">
                                Created: @sheet.CreatedAt.ToString("MMM dd, yyyy")
                                <br />
                                Updated: @sheet.UpdatedAt.ToString("MMM dd, yyyy")
                            </p>
                        </div>
                        <div class="card-footer bg-transparent border-top">
                            <a href="/Sheets/Editor/@sheet.Id" class="btn btn-sm btn-primary">
                                <i class="fas fa-edit"></i> Edit
                            </a>
                            <div class="btn-group" role="group">
                                <button type="button" class="btn btn-sm btn-success dropdown-toggle" data-bs-toggle="dropdown">
                                    <i class="fas fa-download"></i> Export
                                </button>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" href="#" onclick="exportSheet(@sheet.Id, 'gdrive')">
                                        <i class="fab fa-google-drive text-success"></i> Save to Google Drive
                                    </a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" href="#" onclick="exportSheet(@sheet.Id, 'xlsx')">
                                        <i class="fas fa-file-excel"></i> Excel (.xlsx)
                                    </a></li>
                                    <li><a class="dropdown-item text-primary" href="#" onclick="exportSheetApi(@sheet.Id)">
                                        <i class="fas fa-bolt"></i> Excel via API (.xlsx)
                                    </a></li>
                                    <li><a class="dropdown-item" href="#" onclick="exportSheet(@sheet.Id, 'csv')">
                                        <i class="fas fa-file-csv"></i> CSV (.csv)
                                    </a></li>
                                    <li><a class="dropdown-item" href="#" onclick="exportSheet(@sheet.Id, 'ods')">
                                        <i class="fas fa-file-alt"></i> OpenDocument (.ods)
                                    </a></li>
                                    <li><a class="dropdown-item" href="#" onclick="exportSheet(@sheet.Id, 'html')">
                                        <i class="fas fa-code"></i> HTML (.html)
                                    </a></li>
                                </ul>
                            </div>
                            <button class="btn btn-sm btn-danger" onclick="deleteSheet(@sheet.Id)">
                                <i class="fas fa-trash"></i> Delete
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (ViewBag.TotalPages > 1)
        {
            <nav aria-label="Page navigation" class="mt-4">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link" href="?page=@(ViewBag.CurrentPage - 1)">Previous</a>
                    </li>
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                            <a class="page-link" href="?page=@i">@i</a>
                        </li>
                    }
                    <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                        <a class="page-link" href="?page=@(ViewBag.CurrentPage + 1)">Next</a>
                    </li>
                </ul>
            </nav>
        }
    }
    else
    {
        <div class="alert alert-info text-center py-5">
            <i class="fas fa-inbox fa-3x mb-3"></i>
            <p>No spreadsheets yet. <a href="#" onclick="createNewSheet()">Create one now!</a></p>
        </div>
    }
</div>

<!-- Import Modal -->
<div class="modal fade" id="importModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <script src="~/js/xlsx.full.min.js"></script>
                <h5 class="modal-title"><i class="fas fa-file-import"></i> Import Spreadsheet</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="importForm" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label for="fileInput" class="form-label">Select Excel, ODS, or CSV File</label>
                        <input type="file" class="form-control" id="fileInput" name="file" accept=".xlsx,.xls,.csv,.ods" required />
                        <small class="text-muted">Supported formats: Excel (.xlsx, .xls), OpenDocument (.ods), CSV</small>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="importSheet()">
                    <i class="fas fa-upload"></i> Import
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function createNewSheet() {
            const sheetName = prompt("Enter sheet name:");
            if (!sheetName) return;

            fetch('/Sheets/Create', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: JSON.stringify({ fileName: sheetName })
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    window.location.href = `/Sheets/Editor/${data.id}`;
                } else {
                    alert('Error creating sheet: ' + data.message);
                }
            })
            .catch(e => {
                alert('Error: ' + e.message);
            });
        }

        document.getElementById('btnNewSheet').addEventListener('click', createNewSheet);

        function exportSheet(sheetId, format) {
            if (format === 'gdrive') {
                window.location.href = `/sheets/export-gdrive/${sheetId}`;
            } else if (format) {
                window.location.href = `/Sheets/Export-Format/${sheetId}/${format}`;
            } else {
                window.location.href = `/Sheets/Export/${sheetId}`;
            }
        }

        async function exportSheetApi(sheetId) {
            try {
                // Show a simple loading indicator in the button if possible, or just alert
                const response = await fetch(`/api/spreadsheet/export/${sheetId}`);
                if (!response.ok) throw new Error("Failed to fetch export data");
                const data = await response.json();
                
                const wb = XLSX.utils.book_new();
                
                data.sheets.forEach(sheet => {
                    const ws = XLSX.utils.aoa_to_sheet([]);
                    
                    // Default range if empty
                    let maxR = -1;
                    let maxC = -1;
                    
                    // Add cells
                    if (sheet.cells) {
                        sheet.cells.forEach(c => {
                            const ref = XLSX.utils.encode_cell({c: c.c, r: c.r});
                            ws[ref] = { t: c.t, v: c.v };
                            if (c.f) ws[ref].f = c.f; // add formula
                            
                            if(c.c > maxC) maxC = c.c;
                            if(c.r > maxR) maxR = c.r;
                        });
                    }
                    
                    // Add merges
                    if (sheet.merges && sheet.merges.length > 0) {
                        ws['!merges'] = sheet.merges.map(m => ({
                            s: { r: m.s.r, c: m.s.c },
                            e: { r: m.e.r, c: m.e.c }
                        }));
                    }
                    
                    // Add col widths
                    if (sheet.cols && sheet.cols.length > 0) {
                        ws['!cols'] = [];
                        sheet.cols.forEach(col => {
                            ws['!cols'][col.index] = { wpx: col.size };
                        });
                    }
                    
                    // Set final range bounding box
                    if (maxR >= 0 && maxC >= 0) {
                        ws['!ref'] = XLSX.utils.encode_range({s:{c:0,r:0}, e:{c:maxC, r:maxR}});
                    } else {
                        ws['!ref'] = "A1:A1";
                    }
                    
                    XLSX.utils.book_append_sheet(wb, ws, sheet.name || "Sheet");
                });
                
                XLSX.writeFile(wb, `${data.fileName || 'export'}.xlsx`);
            } catch (e) {
                console.error(e);
                alert("Error exporting via API: " + e.message);
            }
        }


        // Safe rename sheet listener using data attributes to prevent Stored XSS
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('.btn-rename').forEach(button => {
                button.addEventListener('click', function() {
                    const sheetId = this.getAttribute('data-sheet-id');
                    const currentName = this.getAttribute('data-filename');
                    const newName = prompt("Enter new name for the spreadsheet:", currentName);
                    
                    if (newName && newName.trim() !== "" && newName !== currentName) {
                        fetch(`/Sheets/Rename/${sheetId}`, {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                            },
                            body: JSON.stringify({ fileName: newName.trim() })
                        })
                        .then(r => r.json())
                        .then(data => {
                            if (data.success) {
                                document.getElementById(`sheetName-${sheetId}`).innerText = data.fileName;
                                this.setAttribute('data-filename', data.fileName);
                            } else {
                                alert('Error renaming sheet: ' + (data.message || 'Unknown error'));
                            }
                        })
                        .catch(err => {
                            console.error('Error:', err);
                            alert('Network error while renaming sheet');
                        });
                    }
                });
            });
        });

        function deleteSheet(sheetId) {
            if (!confirm('Are you sure you want to delete this sheet?')) {
                return;
            }

            fetch(`/Sheets/Delete/${sheetId}`, { 
                method: 'POST',
                headers: {
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                }
            })
            .then(r => {
                return r.json();
            })
            .then(data => {
                if (data.success) {
                    window.location.href = window.location.pathname + '?t=' + Date.now();
                } else {
                    alert('Error deleting sheet: ' + data.message);
                }
            })
            .catch(e => {
                alert('Error: ' + e.message);
            });
        }

        function importSheet() {
            const fileInput = document.getElementById('fileInput');
            const file = fileInput.files[0];
            
            if (!file) {
                alert("Please select a file first.");
                return;
            }

            const maxSize = 5 * 1024 * 1024; // 5MB limit
            if (file.size > maxSize) {
                alert("File too large, max 5MB. Please choose a smaller file.");
                fileInput.value = ''; // Reset input
                return;
            }

            const reader = new FileReader();
            reader.onload = function(e) {
                try {
                    const data = new Uint8Array(e.target.result);
                    const wb = XLSX.read(data, {type: 'array'});
                    
                    let sheetsData = [];
                    wb.SheetNames.forEach((sheetName, index) => {
                        const ws = wb.Sheets[sheetName];
                        let cells = [];
                        
                        if (ws['!ref']) {
                            const range = XLSX.utils.decode_range(ws['!ref']);
                            for(let R = range.s.r; R <= range.e.r; ++R) {
                                for(let C = range.s.c; C <= range.e.c; ++C) {
                                    const cellRef = XLSX.utils.encode_cell({c:C, r:R});
                                    const cell = ws[cellRef];
                                    if (!cell) continue;
                                    
                                    cells.push({
                                        r: R,
                                        c: C,
                                        v: cell.v,
                                        t: (typeof cell.v === 'number') ? 'n' : 's',
                                        f: cell.f || null
                                    });
                                }
                            }
                        }
                        
                        let merges = [];
                        if (ws['!merges']) {
                            ws['!merges'].forEach(m => {
                                merges.push({
                                    s: { r: m.s.r, c: m.s.c },
                                    e: { r: m.e.r, c: m.e.c }
                                });
                            });
                        }
                        
                        let cols = [];
                        if (ws['!cols']) {
                            ws['!cols'].forEach((c, idx) => {
                                if (c && c.wch) {
                                    cols.push({ index: idx, size: c.wch * 7 }); // Roughly convert char width to px
                                }
                            });
                        }
                        
                        let rows = [];
                        if (ws['!rows']) {
                            ws['!rows'].forEach((r, idx) => {
                                if (r && r.hpt) {
                                    rows.push({ index: idx, size: r.hpt });
                                }
                            });
                        }
                        
                        sheetsData.push({
                            name: sheetName,
                            cells: cells,
                            merges: merges,
                            cols: cols,
                            rows: rows
                        });
                    });
                    
                    const cleanFileName = file.name.replace(/[^a-zA-Z0-9 _\-\.]/g, "").trim() || "Imported Sheet";
                    const payload = {
                        fileName: cleanFileName,
                        sheets: sheetsData
                    };
                    
                    const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
                    
                    fetch('/api/spreadsheet/import', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': token
                        },
                        body: JSON.stringify(payload)
                    })
                    .then(r => r.json())
                    .then(data => {
                        if (data.success) {
                            bootstrap.Modal.getInstance(document.getElementById('importModal')).hide();
                            window.location.href = `/Sheets/Editor/${data.id}`;
                        } else {
                            alert("Error creating sheet: " + (data.message || "Unknown error"));
                        }
                    })
                    .catch(err => {
                        alert('API Error: ' + err.message);
                    });
                    
                } catch(err) {
                    console.error(err);
                    alert("Error parsing Excel file with SheetJS: " + err.message);
                }
            };
            
            reader.readAsArrayBuffer(file);
        }

        // Check if we just saved a sheet and auto-refresh if needed
        document.addEventListener('DOMContentLoaded', function() {
            if (localStorage.getItem('justSavedSheet') === 'true') {
                localStorage.removeItem('justSavedSheet');
                window.location.reload();
            }
        });
    </script>
}
