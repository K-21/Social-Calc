{
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER;Database=social_calc;Trusted_Connection=true;"
  },
  "AppSettings": {
    "AppTitle": "Social Calc",
    "SecretKey": "GENERATE_A_SECURE_RANDOM_KEY_HERE",
    "JwtSecret": "GENERATE_A_SECURE_JWT_SECRET_HERE",
    "TokenExpirationMinutes": 60,
    "PhpServiceUrl": "http://localhost:8000/excelinterop/",
    "UsePhpCli": true,
    "PhpCliPath": "php",
    "PhpScriptsDir": "excelinterop",
    "PhpTempDir": "excelinterop/tmp",
    "PhpCliTimeoutSeconds": 30
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Email": {
    "From": "noreply@yourdomain.com",
    "SmtpServer": "smtp.yourdomain.com",
    "SmtpPort": 587,
    "UseCredentials": true,
    "Username": "YOUR_SMTP_USERNAME",
    "Password": "YOUR_SMTP_PASSWORD"
  },
  "FileStorage": {
    "Type": "FileSystem",
    "BasePath": "uploads/",
    "MaxFileSize": 52428800
  }
}
